# App private key (get it from Vana Gateway: https://account.vana.org/admin)
VANA_PRIVATE_KEY=0x...
# Public URL of your app. Do NOT include a trailing slash.
APP_URL=http://localhost:3001
# Required: comma-separated scopes for Amazon + Shopify order history
# Scope list/schemas: https://github.com/vana-com/data-connectors/tree/main/schemas
VANA_SCOPES=amazon.orders,amazon.profile,shop.orders
# Vana environment: "dev" or "prod"
VANA_ENVIRONMENT=dev

# LLM for shopping chat (OpenAI-compatible endpoint)
# Gemini: https://aistudio.google.com/apikey
LLM_API_KEY=
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_MODEL=gemini-2.0-flash
